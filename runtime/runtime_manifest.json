{
  "version": 1,
  "runtimes": [
    {
      "name": "Bun",
      "check": "JavaScript/TypeScript Runtime",
      "required": false,
      "candidates": ["bun"],
      "versionArgs": ["--version"],
      "minVersion": "1.0.0",
      "installHint": "Install from https://bun.sh or run: curl -fsSL https://bun.sh/install | bash",
      "installers": {
        "windows": [
          { "manager": "winget", "package": "Oven-sh.Bun" },
          { "manager": "scoop", "package": "bun" }
        ],
        "darwin": [
          { "manager": "brew", "package": "oven-sh/bun/bun" }
        ],
        "linux": []
      }
    },
    {
      "name": "Python",
      "check": "Python Runtime",
      "required": false,
      "candidates": ["python3", "python"],
      "versionArgs": ["--version"],
      "minVersion": "3.8.0",
      "installHint": "Install from https://python.org",
      "installers": {
        "windows": [
          { "manager": "winget", "package": "Python.Python.3.12" }
        ],
        "darwin": [
          { "manager": "brew", "package": "python3" }
        ],
        "linux": [
          { "manager": "apt-get", "package": "python3" }
        ]
      }
    },
    {
      "name": "LuaJIT",
      "check": "LuaJIT Runtime",
      "required": false,
      "candidates": ["luajit"],
      "versionArgs": ["-v"],
      "minVersion": "2.1.0",
      "installHint": "Install LuaJIT from https://luajit.org or via system package manager",
      "installers": {
        "windows": [
          { "manager": "choco", "package": "luajit" },
          { "manager": "scoop", "package": "luajit" }
        ],
        "darwin": [
          { "manager": "brew", "package": "luajit" }
        ],
        "linux": [
          { "manager": "apt-get", "package": "luajit" }
        ]
      }
    },
    {
      "name": "Ruby",
      "check": "Ruby Runtime",
      "required": false,
      "candidates": ["ruby"],
      "versionArgs": ["--version"],
      "minVersion": "3.3.0",
      "installHint": "Install Ruby 3.3+ from https://ruby-lang.org",
      "installers": {
        "windows": [
          { "manager": "winget", "package": "RubyInstallerTeam.RubyWithDevKit.3.3" }
        ],
        "darwin": [
          { "manager": "brew", "package": "ruby" }
        ],
        "linux": [
          { "manager": "apt-get", "package": "ruby" }
        ]
      }
    }
  ]
}
