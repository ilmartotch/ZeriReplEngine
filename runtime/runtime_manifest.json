{
  "version": 1,
  "runtimes": [
    {
      "name": "bun",
      "check": "JavaScript Runtime",
      "required": true,
      "candidates": ["bun", "bun.exe"],
      "versionArgs": ["--version"],
      "minVersion": "1.0.0",
      "installHint": "Install or update Bun from https://bun.sh/docs/installation and ensure it is available in PATH.",
      "installers": {
        "windows": [
          { "manager": "winget", "package": "Oven-sh.Bun" },
          { "manager": "choco", "package": "bun" },
          { "manager": "scoop", "package": "bun" }
        ],
        "darwin": [
          { "manager": "brew", "package": "bun" }
        ],
        "linux": [
          { "manager": "apt-get", "package": "bun" },
          { "manager": "dnf", "package": "bun" },
          { "manager": "yum", "package": "bun" },
          { "manager": "pacman", "package": "bun" },
          { "manager": "zypper", "package": "bun" },
          { "manager": "apk", "package": "bun" }
        ]
      }
    },
