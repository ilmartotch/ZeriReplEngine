{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ilmartotch/ReplZeriEmgine/docs/plugin-manifest-schema.json",
  "title": "Zeri Plugin Manifest",
  "type": "object",
  "required": [
    "name",
    "version",
    "description",
    "author",
    "abi_version",
    "entry"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "abi_version": {
      "type": "integer",
      "minimum": 1
    },
    "entry": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "name": "my-plugin",
      "version": "1.0.0",
      "description": "Example plugin for Zeri",
      "author": "Example Author",
      "abi_version": 1,
      "entry": "my-plugin.dll"
    }
  ]
}
